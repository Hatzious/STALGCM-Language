<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="../print.xsl" ?>
<?xml-stylesheet type="text/css" href="../rules.css" title="Easy editing stylesheet" ?>
<rules lang="tl" xsi:noNamespaceSchemaLocation="../rules.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema">   
    <category name="Filipino Text Shortcut">    
        <rule id="NAMAN" name="namang">
            <pattern case_sensitive="no">
                <token regexp="yes">nm[a]?n(g)?</token>
            </pattern>
            <message>
                Using shortcuts for naman/namang is incorrect. It must be <suggestion><match no="1" regexp_match="(?i)nm[a]?n(g?)" case_conversion="startlower" regexp_replace="naman$1"/></suggestion>
            </message>
            <short>Namang Correction</short>
            <example correction="naman" type="incorrect">Masarap <marker>nmn</marker> ang hamonado.</example>
            <example type="correct">Masarap <marker>naman</marker> ang hamonado.</example>
            <example correction="namang" type="incorrect">Wala ka na <marker>nmng</marker> ambag.</example>
            <example type="correct">Wala ka na <marker>namang</marker> ambag.</example>
        </rule>

        <rule id="WLA" name="wala">
            <pattern case_sensitive="no">
                <token regexp="yes">wla</token>
            </pattern>
            <message>
                Wala must be completed. Correct form is <suggestion><match no="1" regexp_match="(?i)wla" case_conversion="startlower" regexp_replace="wala"/></suggestion>
            </message>
            <short>Wala Correction</short>
            <example correction="Wala" type="incorrect"><marker>Wla</marker> pa akong pera.</example>
            <example type="correct">Hindi ka pa rin dapat sumusuko kahit <marker>wala</marker> ka nang pera.</example>
        </rule>
